{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/check-agent-spawn.js"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/check-subagent-start.js"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/check-agent-spawn-result.js"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Agent([ORCHESTRATOR_AGENT])",
      "Agent([SERVER_AGENT])",
      "Agent([FRONTEND_AGENT])",
      "Agent([QA_AGENT])",
      "Agent([FIX_AGENT])"
    ],
    "deny": [
      "Agent(Explore)",
      "Agent(Plan)"
    ]
  }
}
